# Solar Configuration
# Copy this file to ~/.solar/.env and fill in your API keys

# ==================== Claude (Anthropic) ====================
ANTHROPIC_API_KEY=sk-ant-api03-...

# ==================== OpenAI ====================
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

# ==================== Google Gemini ====================
GOOGLE_API_KEY=...
GEMINI_DEFAULT_MODEL=gemini-1.5-pro

# ==================== Deepseek ====================
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ==================== GLM (智谱清言) ====================
GLM_API_KEY=...
GLM_DEFAULT_MODEL=glm-4-flash

# ==================== Minimax ====================
MINIMAX_API_KEY=...
MINIMAX_GROUP_ID=...
MINIMAX_DEFAULT_MODEL=abab6.5-chat

# ==================== Model Routing ====================
# Map task complexity to models
MODEL_ROUTE_SIMPLE=glm-4-flash
MODEL_ROUTE_MEDIUM=deepseek-chat
MODEL_ROUTE_COMPLEX=claude-opus-4-5-20251101

# ==================== Cost Control ====================
# Daily budget in USD
DAILY_BUDGET_USD=10.0

# Prefer cheaper models when possible
PREFER_CHEAP_MODEL=true

# Alert threshold (percentage of daily budget)
BUDGET_ALERT_THRESHOLD=80

# ==================== Daemon Settings ====================
# Socket path (default: /tmp/solar.sock)
SOLAR_SOCKET_PATH=/tmp/solar.sock

# Message sync interval in ms (default: 1000)
SOLAR_SYNC_INTERVAL=1000

# Health check interval in ms (default: 5000)
SOLAR_HEALTH_CHECK_INTERVAL=5000

# ==================== Database ====================
# SQLite database path (default: ~/.solar/solar.db)
SOLAR_DB_PATH=~/.solar/solar.db

# ==================== Plugins ====================
# Plugin directory (default: ~/.solar/plugins)
SOLAR_PLUGIN_DIR=~/.solar/plugins

# Auto-load plugins on startup
SOLAR_AUTO_LOAD_PLUGINS=true

# ==================== Logging ====================
# Log level: debug, info, warn, error
SOLAR_LOG_LEVEL=info

# Max log file size in MB
SOLAR_MAX_LOG_SIZE=10

# Log retention days
SOLAR_LOG_RETENTION_DAYS=7
