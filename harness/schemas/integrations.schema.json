{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Solar External Integrations Health Schema",
  "version": "1.0.0",
  "frozen_since": "2026-05-08",
  "description": "Schema for the output of external-integrations-health.py (six-state per-integration model)",
  "type": "object",
  "required": ["generated_at", "summary", "integrations"],
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp when probe was run"
    },
    "summary": {
      "type": "object",
      "required": ["ok", "warn", "missing", "total"],
      "properties": {
        "ok": { "type": "integer", "minimum": 0 },
        "warn": { "type": "integer", "minimum": 0 },
        "missing": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 1 }
      }
    },
    "integrations": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "$ref": "#/definitions/integration"
      }
    },
    "cache": {
      "type": "object",
      "properties": {
        "hit": { "type": "boolean" },
        "age_s": { "type": "number" }
      }
    }
  },
  "definitions": {
    "integration": {
      "type": "object",
      "required": ["name", "source", "purpose", "installed", "configured", "running", "indexed", "used_by_default", "status", "degraded_reason", "evidence"],
      "properties": {
        "name": { "type": "string" },
        "source": { "type": "string" },
        "purpose": { "type": "string" },
        "installed": { "type": "boolean" },
        "configured": { "type": "boolean" },
        "running": { "type": "boolean" },
        "indexed": { "type": "boolean" },
        "used_by_default": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["ok", "warn", "missing"]
        },
        "degraded_reason": { "type": "string" },
        "evidence": { "type": "object" }
      }
    },
    "sdk_kind": {
      "description": "Mirage SDK integration kind enum",
      "type": "string",
      "enum": ["none", "solar-logical", "strukto-official", "fuse"]
    },
    "drive_state": {
      "description": "Drive mount state enum",
      "type": "string",
      "enum": ["connected", "credentials_missing", "logical_mount", "error"]
    },
    "symphony_mode": {
      "description": "Symphony integration mode enum",
      "type": "string",
      "enum": ["dry_run_sidecar", "primary_executor", "disabled"]
    },
    "owl_connection_status": {
      "description": "OWL connection status enum",
      "type": "string",
      "enum": ["not_connected", "experimental", "production"]
    }
  }
}
