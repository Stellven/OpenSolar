{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Solar Capability Registry Schema",
  "version": "1.0.0",
  "description": "Schema for capability entries stored in state DB and returned by capability_registry.py",
  "type": "object",
  "required": ["capability", "provider", "level"],
  "additionalProperties": false,
  "properties": {
    "capability": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.:-]*$",
      "description": "Capability token (e.g. wiki.read, pdf.extract, graph.render)"
    },
    "provider": {
      "type": "string",
      "description": "Plugin ID that provides this capability"
    },
    "level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "description": "1=dead_end, 2=basic_usable, 3=default_usable, 4=closed_loop"
    },
    "status": {
      "type": "string",
      "enum": ["active", "disabled", "degraded"]
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp"
    },
    "meta": {
      "type": "object",
      "description": "Provider-specific metadata"
    }
  }
}
