{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Solar Experience Memory Schema",
  "description": "Compact workflow memory extracted from terminal sprint artifacts",
  "schema_version": "1.0.0",
  "definitions": {
    "trajectory": {
      "type": "object",
      "required": ["schema_version", "sid", "status", "phase", "trigger_sig", "events_summary", "extracted_at"],
      "properties": {
        "schema_version": {"type": "string"},
        "sid": {"type": "string"},
        "status": {"type": "string", "enum": ["passed", "failed", "cancelled", "quarantined"]},
        "phase": {"type": "string"},
        "trigger_sig": {"type": "string", "description": "hash of trigger conditions"},
        "tags": {"type": "array", "items": {"type": "string"}},
        "events_summary": {
          "type": "object",
          "properties": {
            "total_events": {"type": "integer"},
            "c_u_events": {"type": "integer"},
            "dispatch_events": {"type": "integer"},
            "eval_rounds": {"type": "integer"},
            "duration_minutes": {"type": "number"}
          }
        },
        "state_sig": {"type": "string", "description": "hash of state at trigger time"},
        "anti_patterns": {"type": "array", "items": {"type": "string"}},
        "outcome": {"type": "string", "enum": ["success", "failure", "partial"]},
        "repair_actions": {"type": "array", "items": {"type": "string"}},
        "extracted_at": {"type": "string", "format": "date-time"}
      }
    },
    "entry": {
      "type": "object",
      "required": ["schema_version", "entry_id", "trigger_sig", "pattern_class", "outcome", "created_at"],
      "properties": {
        "schema_version": {"type": "string"},
        "entry_id": {"type": "string"},
        "trigger_sig": {"type": "string"},
        "state_sig": {"type": "string"},
        "pattern_class": {
          "type": "string",
          "enum": ["c_u_storm", "mis_dispatch", "status_corruption", "terminal_phase_wake", "queue_block", "success_workflow", "repair_recipe"]
        },
        "tags": {"type": "array", "items": {"type": "string"}},
        "outcome": {"type": "string", "enum": ["success", "failure", "partial"]},
        "advisory": {"type": "string", "maxLength": 2048},
        "repair_recipe": {"type": "string", "maxLength": 2048},
        "source_sids": {"type": "array", "items": {"type": "string"}},
        "hit_count": {"type": "integer", "minimum": 0},
        "last_seen": {"type": "string", "format": "date-time"},
        "created_at": {"type": "string", "format": "date-time"}
      }
    }
  },
  "oneOf": [
    {"$ref": "#/definitions/trajectory"},
    {"$ref": "#/definitions/entry"}
  ]
}
