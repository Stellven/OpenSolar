{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solar.local/schemas/requirement-ir.schema.json",
  "title": "Solar Requirement IR",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "request_type",
    "priority",
    "lane_hint",
    "source_inputs",
    "user_intent",
    "normalized_goal",
    "assumptions",
    "open_questions",
    "risk_register",
    "requirements",
    "scheduling",
    "confidence",
    "prd_view",
    "contracts",
    "dag_view",
    "handoff_view",
    "evidence_policy"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "solar.requirement_ir.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "request_type": {
      "type": "string",
      "enum": ["implementation", "full_prd", "research"]
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "lane_hint": {
      "type": "string",
      "minLength": 1
    },
    "source_inputs": {
      "type": "object",
      "required": ["raw_request", "papers", "logs", "repo_context"],
      "additionalProperties": true,
      "properties": {
        "raw_request": { "type": "string" },
        "papers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "logs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "repo_context": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "user_intent": { "type": "string", "minLength": 1 },
    "normalized_goal": { "type": "string", "minLength": 1 },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_register": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "level", "title", "mitigation"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "level": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "title": { "type": "string" },
          "mitigation": { "type": "string" }
        }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "source_text", "success_criteria", "verification_method", "priority"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source_text": { "type": "string", "minLength": 1 },
          "success_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "verification_method": { "type": "string", "minLength": 1 },
          "priority": { "type": "string", "minLength": 1 }
        }
      }
    },
    "scheduling": {
      "type": "object",
      "required": ["queue_class", "global_priority_boost", "lane_hint"],
      "additionalProperties": true,
      "properties": {
        "queue_class": { "type": "string", "minLength": 1 },
        "global_priority_boost": { "type": "number" },
        "lane_hint": { "type": "string", "minLength": 1 }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "prd_view": {
      "type": "object",
      "required": ["variant", "sections"],
      "additionalProperties": true,
      "properties": {
        "variant": {
          "type": "string",
          "enum": ["short", "standard", "research"]
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "body"],
            "properties": {
              "title": { "type": "string" },
              "body": { "type": "string" }
            }
          }
        }
      }
    },
    "contracts": {
      "type": "object",
      "required": ["product", "interface", "agent_execution", "research"],
      "additionalProperties": true,
      "properties": {
        "product": { "type": "object", "additionalProperties": true },
        "interface": { "type": "object", "additionalProperties": true },
        "agent_execution": { "type": "object", "additionalProperties": true },
        "research": { "type": "object", "additionalProperties": true }
      }
    },
    "dag_view": {
      "type": "object",
      "required": ["dag_variant", "nodes"],
      "additionalProperties": true,
      "properties": {
        "dag_variant": {
          "type": "string",
          "enum": ["short", "standard", "parallel_spec", "research"]
        },
        "nodes": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "handoff_view": {
      "type": "object",
      "required": ["codex", "solar_harness"],
      "additionalProperties": true,
      "properties": {
        "codex": { "type": "object", "additionalProperties": true },
        "solar_harness": { "type": "object", "additionalProperties": true }
      }
    },
    "evidence_policy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
