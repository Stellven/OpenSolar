{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solar.local/schemas/draft/ai-infra-pack.v1.draft.json",
  "title": "AI Infra Pack v1",
  "description": "Draft schema for AIInfraPack - pre-packaged suite of model credentials, MCP server mappings, and security policies.",
  "schema_status": "draft",
  "schema_version": "v1.0.0-draft",
  "type": "object",
  "required": [
    "pack_id",
    "pack_name",
    "version",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "pack_id": {
      "type": "string"
    },
    "pack_name": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[a-z0-9.]+)?$"
    },
    "status": {
      "type": "string",
      "enum": [
        "stable",
        "draft",
        "deprecated"
      ]
    },
    "mcp_servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "endpoint_type"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "endpoint_type": {
            "type": "string",
            "enum": [
              "mcp_stdio",
              "mcp_sse",
              "mcp_http"
            ]
          },
          "url": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "disabled",
              "degraded"
            ]
          }
        }
      }
    },
    "operator_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role",
          "vendor"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "vendor": {
            "type": "string"
          },
          "allowed_models": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "timeout_seconds": {
            "type": "integer"
          }
        }
      }
    },
    "common_policies": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "Policy IDs that apply to all execution pipelines using this pack."
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
