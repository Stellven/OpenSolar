{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "influence.output.action_queue.v1",
  "title": "ActionQueue",
  "type": "object",
  "required": ["schema_version", "asset_type", "packet_id", "thesis_id"],
  "properties": {
    "schema_version": {"const": "influence.output.action_queue.v1"},
    "asset_type": {"const": "action_queue"},
    "packet_id": {"type": "string"},
    "thesis_id": {"type": "string"},
    "actionability": {"type": "number"},
    "next_actions": {"type": "array", "items": {"type": "string"}}
  }
}
