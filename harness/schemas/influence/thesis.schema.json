{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "influence.thesis.v1",
  "title": "Thesis",
  "type": "object",
  "required": ["schema_version", "thesis_id", "claim", "derived_from_statements"],
  "properties": {
    "schema_version": {"const": "influence.thesis.v1"},
    "thesis_id": {"type": "string", "minLength": 1},
    "derived_from_statements": {"type": "array", "items": {"type": "string"}},
    "claim": {"type": "string", "minLength": 1},
    "viewpoint_cluster": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "extraction_method": {"type": "string"},
    "extraction_source": {"type": "string"}
  }
}
