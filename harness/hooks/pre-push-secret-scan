#!/usr/bin/env bash
# ============================================================================
# Solar Product Platform — Pre-push Secret Scan Hook
#
# Runs gitleaks on full worktree diff against remote. Blocks push if secrets found.
# Install: ln -s hooks/pre-push-secret-scan .git/hooks/pre-push
#
# Stop condition: any secret leak → blocks push. No exceptions.
# ============================================================================
set -euo pipefail

red()   { printf '\033[31m%s\033[0m\n' "$*" >&2; }
green() { printf '\033[32m%s\033[0m\n' "$*" >&2; }

HARNESS_DIR="$(git rev-parse --show-toplevel 2>/dev/null || echo "$(cd "$(dirname "$0")/../.." && pwd)")"
GITLEAKS_CONFIG="${HARNESS_DIR}/gitleaks.toml"

if ! command -v gitleaks &>/dev/null; then
  echo "[pre-push-secret-scan] ERROR: gitleaks not installed — BLOCKING push" >&2
  echo "[pre-push-secret-scan] Install: brew install gitleaks" >&2
  exit 1
fi

if [[ ! -f "$GITLEAKS_CONFIG" ]]; then
  echo "[pre-push-secret-scan] ERROR: gitleaks.toml not found — BLOCKING push" >&2
  exit 1
fi

echo "[pre-push-secret-scan] Scanning full worktree..."

# Read remote refs from stdin (git push provides these)
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
    continue  # branch deletion, skip
  fi

  echo "[pre-push-secret-scan] Scanning range: $local_sha..$remote_sha"

  if gitleaks detect \
      --config="$GITLEAKS_CONFIG" \
      --source="$HARNESS_DIR" \
      --log-opts="${local_sha}..${remote_sha}" \
      --verbose 2>&1; then
    green "[pre-push-secret-scan] PASS — no secrets in push range"
  else
    red "===================================================================="
    red "  SECRET SCAN FAILED: Potential secrets in push range"
    red "  Push BLOCKED. Remove real secrets before pushing."
    red "  Never bypass this check — it protects all users of this repo."
    red "===================================================================="
    exit 1
  fi
done

exit 0
