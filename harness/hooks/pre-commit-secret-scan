#!/usr/bin/env bash
# ============================================================================
# Solar Product Platform — Pre-commit Secret Scan Hook
#
# Runs gitleaks on staged changes. Blocks commit if secrets found.
# Install: ln -s hooks/pre-commit-secret-scan .git/hooks/pre-commit
#
# Stop condition: any secret leak → blocks commit.
# ============================================================================
set -euo pipefail

red()   { printf '\033[31m%s\033[0m\n' "$*" >&2; }
green() { printf '\033[32m%s\033[0m\n' "$*" >&2; }

HARNESS_DIR="$(git rev-parse --show-toplevel 2>/dev/null || echo "$(cd "$(dirname "$0")/../.." && pwd)")"
GITLEAKS_CONFIG="${HARNESS_DIR}/gitleaks.toml"

# Skip if no gitleaks installed (non-blocking, warn only)
if ! command -v gitleaks &>/dev/null; then
  echo "[pre-commit-secret-scan] WARNING: gitleaks not installed — skipping scan" >&2
  echo "[pre-commit-secret-scan] Install: brew install gitleaks" >&2
  exit 0
fi

# Skip if no config file
if [[ ! -f "$GITLEAKS_CONFIG" ]]; then
  echo "[pre-commit-secret-scan] WARNING: gitleaks.toml not found — skipping scan" >&2
  exit 0
fi

echo "[pre-commit-secret-scan] Scanning staged changes..."

# Run gitleaks on staged changes
if gitleaks detect \
    --config="$GITLEAKS_CONFIG" \
    --staged \
    --verbose 2>&1; then
  green "[pre-commit-secret-scan] PASS — no secrets found"
  exit 0
else
  red "================================================================"
  red "  SECRET SCAN FAILED: Potential secrets found in staged changes"
  red "  Review the findings above and remove real secrets."
  red "  If these are test/fake keys in allowed paths, add to gitleaks.toml allowlist."
  red "================================================================"
  exit 1
fi
