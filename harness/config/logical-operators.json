  "workflow_vocabulary": {
    "_comment": "Workflow stage names used by APO logical workflow expander. Each stage maps to one or more existing logical_operators. Multiple operators may be selected per stage based on capsule and signal context.",
    "ScanContext": {
      "description": "Gather all relevant context: repository state, benchmark history, existing tickets, related code. Read-only phase.",
      "maps_to_operators": ["ResearchScout", "ResearchSynthesizer"],
      "stage_type": "read_only",
      "position": 1
    },
    "DebugRCA": {
      "description": "Root cause analysis: identify what changed, why performance degraded, or where the bug originates.",
      "maps_to_operators": ["RootCauseDebugger"],
      "stage_type": "analysis",
      "position": 2
    },
    "DesignSolution": {
      "description": "Architect the fix, optimization, or feature. May produce a design doc, interface sketch, or algorithm outline.",
      "maps_to_operators": ["DeepArchitect"],
      "stage_type": "design",
      "position": 3
    },
    "ImplementPatch": {
      "description": "Write the actual code change, patch, or module. Uses ImplementationWorker for features or PatchWorker for surgical fixes.",
      "maps_to_operators": ["ImplementationWorker", "PatchWorker"],
      "stage_type": "implementation",
      "position": 4
    },
    "RunBenchmark": {
      "description": "Execute the benchmark suite to measure before/after impact. Requires shell access.",
      "maps_to_operators": ["BenchmarkRunner"],
      "stage_type": "evaluation",
      "position": 5
    },
    "ReviewPatch": {
      "description": "Critical review of the patch/implementation: correctness, security, style, invariant preservation.",
      "maps_to_operators": ["Critic", "SecurityGate"],
      "stage_type": "review",
      "position": 6
    },
    "VerifyEvidence": {
      "description": "Final acceptance: confirm outputs exist, evidence matches pass_conditions, sign off for promotion.",
      "maps_to_operators": ["Verifier", "ArtifactCurator"],
      "stage_type": "verification",
      "position": 7
    }
  },
  "workflow_templates": {
    "performance_debug_workflow": {
      "description": "7-stage workflow for performance regression and kernel debug task classes.",
      "stages": ["ScanContext", "DebugRCA", "DesignSolution", "ImplementPatch", "RunBenchmark", "ReviewPatch", "VerifyEvidence"],
      "applicable_task_classes": ["PERFORMANCE_REGRESSION", "PERFORMANCE_KERNEL_DEBUG"]
    },
    "design_and_optimize_workflow": {
      "description": "Workflow for software-hardware co-optimization tasks: design first, then implement and benchmark.",
      "stages": ["ScanContext", "DesignSolution", "ImplementPatch", "RunBenchmark", "VerifyEvidence"],
      "applicable_task_classes": ["SOFT_HW_OPT"]
    },
    "implementation_workflow": {
      "description": "Standard feature implementation workflow.",
      "stages": ["ScanContext", "DesignSolution", "ImplementPatch", "ReviewPatch", "VerifyEvidence"],
      "applicable_task_classes": ["CODE_IMPL_REQUIRED"]
    },
    "prototype_workflow": {
      "description": "Fast prototype: skip design formalism and review gates.",
      "stages": ["ScanContext", "ImplementPatch", "VerifyEvidence"],
      "applicable_task_classes": ["FAST_PROTOTYPE"]
    }
  },
