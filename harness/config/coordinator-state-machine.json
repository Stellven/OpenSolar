{
  "$schema": "https://json-schema.org/draft-07/schema",
  "version": "1.0.0",
  "frozen_since": "2026-05-08",
  "description": "Coordinator Control Plane v2 — canonical transition table. All routing decisions flow through this table.",
  "lifecycle_states": [
    "intake",
    "prd_ready",
    "planning",
    "planning_complete",
    "building",
    "build_complete",
    "evaluating",
    "done",
    "blocked",
    "quarantined",
    "failed",
    "corrupt"
  ],
  "transitions": [
    {
      "id": "intake_to_prd_ready",
      "from": "intake",
      "event": "prd_artifact_present",
      "guard": "exists(prd.md)",
      "to": "prd_ready",
      "requested_role": "planner",
      "required_artifacts": ["prd"],
      "timeout_policy": {"ack": 300, "artifact": 3600},
      "retry_policy": {"max_attempts": 3, "backoff": "linear:120"},
      "note": "PM produced PRD → hand to Planner for design+plan"
    },
    {
      "id": "prd_ready_to_planning_complete",
      "from": "prd_ready",
      "event": "design_plan_present",
      "guard": "exists(design.md) && exists(plan.md) && exists(task_graph.json)",
      "to": "planning_complete",
      "requested_role": "builder_main",
      "required_artifacts": ["design", "plan", "task_graph"],
      "timeout_policy": {"ack": 300, "artifact": 7200},
      "retry_policy": {"max_attempts": 3, "backoff": "linear:120"},
      "note": "Planner produced design+plan+task_graph → hand to DAG Builder scheduler"
    },
    {
      "id": "planning_complete_to_build_complete",
      "from": "planning_complete",
      "event": "handoff_present",
      "guard": "exists(handoff.md)",
      "to": "build_complete",
      "requested_role": "evaluator",
      "required_artifacts": ["handoff"],
      "timeout_policy": {"ack": 300, "artifact": 14400},
      "retry_policy": {"max_attempts": 2, "backoff": "linear:300"},
      "note": "Builder produced handoff → hand to Evaluator"
    },
    {
      "id": "build_complete_to_done",
      "from": "build_complete",
      "event": "eval_pass",
      "guard": "exists(eval.md) && eval_verdict==PASS",
      "to": "done",
      "requested_role": "none",
      "required_artifacts": ["eval"],
      "note": "Evaluator PASS → sprint finalized"
    },
    {
      "id": "build_complete_to_blocked",
      "from": "build_complete",
      "event": "eval_fail",
      "guard": "exists(eval.md) && eval_verdict==FAIL",
      "to": "blocked",
      "requested_role": "builder_main",
      "required_artifacts": ["eval"],
      "retry_policy": {"max_attempts": 3},
      "note": "Evaluator FAIL → Builder must fix and re-submit handoff"
    },
    {
      "id": "blocked_to_build_complete",
      "from": "blocked",
      "event": "handoff_updated",
      "guard": "exists(handoff.md) && handoff_newer_than_eval",
      "to": "build_complete",
      "requested_role": "evaluator",
      "required_artifacts": ["handoff"],
      "note": "Builder fixed issues → re-evaluate"
    },
    {
      "id": "any_to_quarantined",
      "from": "*",
      "event": "status_parse_error",
      "guard": "parse_failed(status.json)",
      "to": "quarantined",
      "requested_role": "watchdog",
      "note": "Corrupt status.json → quarantine and skip"
    }
  ],
  "legacy_combos": [
    {
      "match": {"status": "drafting", "phase": "prd_ready", "handoff_to": "planner"},
      "canonical": {"lifecycle_state": "prd_ready", "lifecycle_role": "planner"},
      "note": "KEY BUG FIX: was mis-routed to PM"
    },
    {
      "match": {"status": "drafting", "phase": ["intake", "", null]},
      "canonical": {"lifecycle_state": "intake", "lifecycle_role": "pm"}
    },
    {
      "match": {"status": "drafting", "phase": "contract_ready"},
      "canonical": {"lifecycle_state": "intake", "lifecycle_role": "pm"}
    },
    {
      "match": {"status": "active"},
      "canonical": {"lifecycle_state": "planning_complete", "lifecycle_role": "builder_main"}
    },
    {
      "match": {"status": "planning"},
      "canonical": {"lifecycle_state": "planning", "lifecycle_role": "evaluator"}
    },
    {
      "match": {"status": "approved"},
      "canonical": {"lifecycle_state": "planning_complete", "lifecycle_role": "builder_main"}
    },
    {
      "match": {"status": "reviewing"},
      "canonical": {"lifecycle_state": "build_complete", "lifecycle_role": "evaluator"}
    },
    {
      "match": {"status": "ready_for_review"},
      "canonical": {"lifecycle_state": "build_complete", "lifecycle_role": "evaluator"}
    },
    {
      "match": {"status": "failed_review"},
      "canonical": {"lifecycle_state": "blocked", "lifecycle_role": "builder_main"}
    },
    {
      "match": {"status": "architect_failed"},
      "canonical": {"lifecycle_state": "blocked", "lifecycle_role": "builder_main"}
    },
    {
      "match": {"status": "architect_reviewing"},
      "canonical": {"lifecycle_state": "build_complete", "lifecycle_role": "evaluator"}
    },
    {
      "match": {"status": "building_parallel"},
      "canonical": {"lifecycle_state": "building", "lifecycle_role": "builder_main"}
    },
    {
      "match": {"status": "needs_human_review"},
      "canonical": {"lifecycle_state": "blocked", "lifecycle_role": "planner"}
    },
    {
      "match": {"status": ["passed", "done", "eval_pass"]},
      "canonical": {"lifecycle_state": "done", "lifecycle_role": "none"}
    },
    {
      "match": {"status": "failed"},
      "canonical": {"lifecycle_state": "failed", "lifecycle_role": "none"}
    },
    {
      "match": {"status": "superseded"},
      "canonical": {"lifecycle_state": "done", "lifecycle_role": "none"}
    },
    {
      "match": {"status": "finalized"},
      "canonical": {"lifecycle_state": "done", "lifecycle_role": "none"}
    }
  ]
}
