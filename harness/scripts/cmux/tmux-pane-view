#!/usr/bin/env bash
# tmux-pane-view: capture-pane polling mirror (local or via ssh)
# Usage: tmux-pane-view <session:window.pane> [lines=60] [interval=1]
set -euo pipefail

TARGET="${1:?usage: tmux-pane-view <session:window.pane> [lines] [interval]}"
LINES="${2:-60}"
INTERVAL="${3:-1}"
HOST="${HOSTNAME:-$(hostname -s 2>/dev/null || echo unknown)}"

while true; do
  clear
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] host=${HOST}  target=${TARGET}  mode=capture  lines=${LINES}"
  echo "------------------------------------------------------------"
  if ! tmux capture-pane -p -t "${TARGET}" -S "-${LINES}" 2>/dev/null; then
    echo "WARN: capture-pane failed for target=${TARGET} — tmux session/pane may not exist yet"
    echo "      Retrying in ${INTERVAL}s ..."
  fi
  sleep "${INTERVAL}"
done
