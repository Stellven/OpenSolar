+"""Intent executor — routes compiled work items through the DAG pipeline."""
+
+from __future__ import annotations
+
+import datetime as dt
+import json
+import os
+from pathlib import Path
+from typing import Any
+
+from .contract import ContractValidator
+from .evidence import EvidenceCollector
+
+
+def _now_iso() -> str:
+    return dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
+
+
+class IntentExecutor:
+    """Executes a compiled intent through the Solar-Harness pipeline.
+
+    This is the main entry point that:
+    1. Validates the execution contract against invariants.
+    2. Checks artifact consistency.
+    3. Produces evidence for verifier visibility.
+    """
+
+    def __init__(
+        self,
+        sprints_dir: Path | None = None,
+        intents_dir: Path | None = None,
+    ):
+        self.sprints_dir = sprints_dir or Path.home() / ".solar" / "harness" / "sprints"
+        self.intents_dir = intents_dir or Path.home() / ".solar" / "harness" / "intents"
+        self.validator = ContractValidator(sprints_dir=self.sprints_dir)
+        self.collector = EvidenceCollector(sprints_dir=self.sprints_dir)
+
+    def _read_json(self, path: Path) -> dict[str, Any]:
+        try:
+            return json.loads(path.read_text(encoding="utf-8"))
+        except (OSError, json.JSONDecodeError):
+            return {}
+
+    def _resolve_sprint_id(self, sprint_id: str) -> str:
+        base = self.sprints_dir / f"{sprint_id}.requirement_ir.json"
+        if base.exists():
+            return sprint_id
+        matches = list(self.sprints_dir.glob(f"*{sprint_id}*.requirement_ir.json"))
+        if matches:
+            return matches[0].stem.replace(".requirement_ir", "")
+        return sprint_id
+
+    def _load_ir(self, sprint_id: str) -> dict[str, Any]:
+        return self._read_json(self.sprints_dir / f"{sprint_id}.requirement_ir.json")
+
+    def _load_task_graph(self, sprint_id: str) -> dict[str, Any]:
+        return self._read_json(self.sprints_dir / f"{sprint_id}.task_graph.json")
+
+    def _resolve_intent_id(self, ir: dict[str, Any]) -> str:
+        return str(ir.get("intent_id", ""))
+
+    def validate_sprint(self, sprint_id: str) -> dict[str, Any]:
+        sid = self._resolve_sprint_id(sprint_id)
+        contract = self.validator.validate(sid)
+        return {
+            "sprint_id": sid,
+            "contract_passed": contract.passed,
+            "errors": [{"check": c.check_id, "message": c.message} for c in contract.errors],
+            "warnings": [{"check": c.check_id, "message": c.message} for c in contract.warnings],
+            "total_checks": len(contract.checks),
+            "validated_at": _now_iso(),
+        }
+
+    def collect_evidence(self, sprint_id: str) -> dict[str, Any]:
+        sid = self._resolve_sprint_id(sprint_id)
+        ir = self._load_ir(sid)
+        tg = self._load_task_graph(sid)
+        return self.collector.collect(sid, ir, tg)
+
+    def execute(self, sprint_id: str, *, node_id: str = "", dry_run: bool = False) -> dict[str, Any]:
+        sid = self._resolve_sprint_id(sprint_id)
+        contract_result = self.validate_sprint(sid)
+        if not contract_result["contract_passed"]:
+            return {
+                "status": "contract_failed",
+                "sprint_id": sid,
+                "contract": contract_result,
+                "executed_at": _now_iso(),
+            }
+
+        evidence = self.collect_evidence(sid)
+        if not dry_run:
+            report_path = self.sprints_dir / f"{sid}.execution_evidence.json"
+            report_path.parent.mkdir(parents=True, exist_ok=True)
+            tmp = report_path.with_suffix(".json.tmp")
+            tmp.write_text(
+                json.dumps(evidence, ensure_ascii=False, indent=2) + "\n",
+                encoding="utf-8",
+            )
+            os.replace(tmp, report_path)
+
+        return {
+            "status": "executed" if not dry_run else "dry_run",
+            "sprint_id": sid,
+            "node_id": node_id,
+            "contract": contract_result,
+            "evidence": evidence,
+            "executed_at": _now_iso(),
+        }
