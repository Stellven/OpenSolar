+"""Execution contract validation against requirement IR invariants."""
+
+from __future__ import annotations
+
+import json
+from dataclasses import dataclass, field
+from pathlib import Path
+from typing import Any
+
+
+@dataclass
+class ContractCheck:
+    check_id: str
+    passed: bool
+    message: str
+    severity: str = "error"  # error | warning
+
+
+@dataclass
+class ContractVerdict:
+    passed: bool
+    checks: list[ContractCheck] = field(default_factory=list)
+
+    @property
+    def errors(self) -> list[ContractCheck]:
+        return [c for c in self.checks if c.severity == "error" and not c.passed]
+
+    @property
+    def warnings(self) -> list[ContractCheck]:
+        return [c for c in self.checks if c.severity == "warning"]
+
+
+class ContractValidator:
+    """Validates a compiled sprint package against contract invariants.
+
+    Invariants (per requirement_ir v1):
+    - Requirement IR is the only source of truth.
+    - DAG nodes[*].id must be unique.
+    - Every acceptance criterion maps to at least one validation step.
+    """
+
+    def __init__(self, sprints_dir: Path | None = None):
+        self.sprints_dir = sprints_dir or Path.home() / ".solar" / "harness" / "sprints"
+
+    def _read_json(self, path: Path) -> dict[str, Any]:
+        try:
+            return json.loads(path.read_text(encoding="utf-8"))
+        except (OSError, json.JSONDecodeError):
+            return {}
+
+    def validate_artifacts_exist(self, sprint_id: str) -> ContractVerdict:
+        checks: list[ContractCheck] = []
+        base = self.sprints_dir / sprint_id
+        required = [
+            ("requirement_ir.json", "Requirement IR"),
+            ("task_graph.json", "Task Graph"),
+            ("contract.md", "Contract"),
+        ]
+        for filename, label in required:
+            path = base if filename == "requirement_ir.json" else self.sprints_dir / f"{sprint_id}.{filename}"
+            # requirement_ir lives in the intent dir but is also copied to sprints dir
+            sprint_path = self.sprints_dir / f"{sprint_id}.{filename}"
+            exists = sprint_path.exists()
+            checks.append(ContractCheck(
+                check_id=f"artifact_exists_{filename}",
+                passed=exists,
+                message=f"{label} at {sprint_path}: {'found' if exists else 'missing'}",
+            ))
+        passed = all(c.passed for c in checks)
+        return ContractVerdict(passed=passed, checks=checks)
+
+    def validate_ir_is_source(self, sprint_id: str) -> ContractVerdict:
+        checks: list[ContractCheck] = []
+        ir_path = self.sprints_dir / f"{sprint_id}.requirement_ir.json"
+        ir = self._read_json(ir_path)
+
+        if not ir:
+            checks.append(ContractCheck(
+                check_id="ir_readable",
+                passed=False,
+                message="Requirement IR is missing or unreadable",
+            ))
+            return ContractVerdict(passed=False, checks=checks)
+
+        checks.append(ContractCheck(
+            check_id="ir_schema_version",
+            passed=ir.get("schema_version") == "solar.requirement_ir.v1",
+            message=f"IR schema_version: {ir.get('schema_version', 'missing')}",
+        ))
+
+        for field_name in ("intent_id", "title", "problem", "objective", "acceptance"):
+            has = bool(ir.get(field_name))
+            checks.append(ContractCheck(
+                check_id=f"ir_field_{field_name}",
+                passed=has,
+                message=f"IR field '{field_name}': {'present' if has else 'missing'}",
+                severity="warning" if field_name == "objective" else "error",
+            ))
+
+        passed = all(c.passed or c.severity == "warning" for c in checks)
+        return ContractVerdict(passed=passed, checks=checks)
+
+    def validate_dag_node_ids_unique(self, sprint_id: str) -> ContractVerdict:
+        checks: list[ContractCheck] = []
+        tg_path = self.sprints_dir / f"{sprint_id}.task_graph.json"
+        tg = self._read_json(tg_path)
+
+        nodes = tg.get("nodes", [])
+        if not nodes:
+            checks.append(ContractCheck(
+                check_id="dag_has_nodes",
+                passed=False,
+                message="Task graph has no nodes",
+            ))
+            return ContractVerdict(passed=False, checks=checks)
+
+        ids = [n.get("id") for n in nodes if n.get("id")]
+        unique = set(ids)
+        duplicates = [i for i in unique if ids.count(i) > 1]
+
+        checks.append(ContractCheck(
+            check_id="dag_node_ids_unique",
+            passed=len(duplicates) == 0,
+            message=f"DAG node IDs: {len(ids)} total, {len(unique)} unique"
+                    + (f", duplicates: {duplicates}" if duplicates else ""),
+        ))
+        return ContractVerdict(passed=len(duplicates) == 0, checks=checks)
+
+    def validate_acceptance_coverage(self, sprint_id: str) -> ContractVerdict:
+        checks: list[ContractCheck] = []
+        tg_path = self.sprints_dir / f"{sprint_id}.task_graph.json"
+        tg = self._read_json(tg_path)
+
+        for node in tg.get("nodes", []):
+            node_id = node.get("id", "?")
+            acceptance = node.get("acceptance", [])
+            validation = node.get("validation", [])
+            has_coverage = len(acceptance) == 0 or len(validation) > 0
+            checks.append(ContractCheck(
+                check_id=f"acceptance_coverage_{node_id}",
+                passed=has_coverage,
+                message=f"Node {node_id}: {len(acceptance)} acceptance criteria, {len(validation)} validation steps",
+                severity="warning" if not has_coverage else "error",
+            ))
+
+        passed = all(c.passed or c.severity == "warning" for c in checks)
+        return ContractVerdict(passed=passed, checks=checks)
+
+    def validate(self, sprint_id: str) -> ContractVerdict:
+        all_checks: list[ContractCheck] = []
+        for verdict in (
+            self.validate_artifacts_exist(sprint_id),
+            self.validate_ir_is_source(sprint_id),
+            self.validate_dag_node_ids_unique(sprint_id),
+            self.validate_acceptance_coverage(sprint_id),
+        ):
+            all_checks.extend(verdict.checks)
+
+        passed = all(c.passed or c.severity == "warning" for c in all_checks)
+        return ContractVerdict(passed=passed, checks=all_checks)
