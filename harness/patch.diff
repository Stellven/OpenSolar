+"""Evidence collector — gathers and verifies execution evidence artifacts."""
+
+from __future__ import annotations
+
+import datetime as dt
+import json
+from pathlib import Path
+from typing import Any
+
+
+def _now_iso() -> str:
+    return dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
+
+
+class EvidenceCollector:
+    """Collects evidence artifacts for a compiled sprint package.
+
+    Verifies that the required artifacts exist and are consistent with the
+    requirement IR and task_graph.
+    """
+
+    REQUIRED_ARTIFACTS = (
+        ("requirement_ir.json", "requirement_ir"),
+        ("task_graph.json", "task_graph"),
+        ("contract.md", "contract"),
+    )
+
+    OPTIONAL_ARTIFACTS = (
+        ("raw_intent.json", "raw_intent"),
+        ("rewritten_intent.json", "rewritten_intent"),
+        ("requirement_trace.json", "requirement_trace"),
+        ("product-brief.md", "product_brief"),
+        ("prd.md", "prd"),
+        ("capsule_plan.json", "capsule_plan"),
+        ("coverage_report.json", "coverage_report"),
+        ("acceptance_verdict.json", "acceptance_verdict"),
+        ("handoff.md", "handoff"),
+    )
+
+    def __init__(self, sprints_dir: Path | None = None):
+        self.sprints_dir = sprints_dir or Path.home() / ".solar" / "harness" / "sprints"
+
+    def _read_json(self, path: Path) -> dict[str, Any]:
+        try:
+            return json.loads(path.read_text(encoding="utf-8"))
+        except (OSError, json.JSONDecodeError):
+            return {}
+
+    def _check_artifact(self, sprint_id: str, filename: str) -> dict[str, Any]:
+        path = self.sprints_dir / f"{sprint_id}.{filename}"
+        exists = path.exists()
+        size = path.stat().st_size if exists else 0
+        return {
+            "filename": filename,
+            "path": str(path),
+            "exists": exists,
+            "size_bytes": size,
+        }
+
+    def check_artifacts(self, sprint_id: str) -> dict[str, Any]:
+        required = [self._check_artifact(sprint_id, f) for f, _ in self.REQUIRED_ARTIFACTS]
+        optional = [self._check_artifact(sprint_id, f) for f, _ in self.OPTIONAL_ARTIFACTS]
+        return {
+            "required": required,
+            "required_all_present": all(a["exists"] for a in required),
+            "optional": optional,
+            "optional_present_count": sum(1 for a in optional if a["exists"]),
+            "total_bytes": sum(a["size_bytes"] for a in required + optional if a["exists"]),
+        }
+
+    def check_node_status(self, task_graph: dict[str, Any]) -> dict[str, Any]:
+        nodes = task_graph.get("nodes", [])
+        results = []
+        for node in nodes:
+            nid = node.get("id", "?")
+            status = node.get("status", "unknown")
+            results.append({
+                "node_id": nid,
+                "status": status,
+                "gate": node.get("gate", ""),
+                "depends_on": node.get("depends_on", []),
+            })
+        return {
+            "nodes": results,
+            "total": len(results),
+            "passed": sum(1 for r in results if r["status"] == "passed"),
+            "pending": sum(1 for r in results if r["status"] in ("pending", "dispatched")),
+            "failed": sum(1 for r in results if r["status"] == "failed"),
+        }
+
+    def check_ir_trace_consistency(
+        self,
+        ir: dict[str, Any],
+        task_graph: dict[str, Any],
+    ) -> dict[str, Any]:
+        ir_intent_id = ir.get("intent_id", "")
+        tg_sprint_id = task_graph.get("sprint_id", "")
+        ir_acceptance = ir.get("acceptance", [])
+        node_count = len(task_graph.get("nodes", []))
+        return {
+            "ir_intent_id": ir_intent_id,
+            "tg_sprint_id": tg_sprint_id,
+            "ir_has_acceptance": len(ir_acceptance) > 0,
+            "ir_acceptance_count": len(ir_acceptance),
+            "tg_node_count": node_count,
+            "consistent": bool(ir_intent_id) and node_count > 0,
+        }
+
+    def collect(
+        self,
+        sprint_id: str,
+        ir: dict[str, Any],
+        task_graph: dict[str, Any],
+    ) -> dict[str, Any]:
+        artifacts = self.check_artifacts(sprint_id)
+        nodes = self.check_node_status(task_graph)
+        consistency = self.check_ir_trace_consistency(ir, task_graph)
+        return {
+            "sprint_id": sprint_id,
+            "collected_at": _now_iso(),
+            "artifacts": artifacts,
+            "nodes": nodes,
+            "consistency": consistency,
+            "overall_pass": artifacts["required_all_present"] and consistency["consistent"],
+        }
