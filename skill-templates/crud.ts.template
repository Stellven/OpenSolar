import { Database } from "bun:sqlite";
import { homedir } from "os";
import { existsSync } from "fs";

// ==================== 配置 ====================

const CONFIG = {
  name: "{{SKILL_NAME}}",
  dbPath: `${homedir()}/.solar/solar.db`,
  tableName: "{{TABLE_NAME}}",
};

// ==================== 类型定义 ====================

interface {{DATA_TYPE}} {
  id: number;
{{DATA_FIELDS}}
  created_at: string;
  updated_at: string;
}

// ==================== 数据库操作 ====================

function initDB(db: Database) {
  db.run(`
    CREATE TABLE IF NOT EXISTS ${CONFIG.tableName} (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
{{TABLE_SCHEMA}}
      created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
      updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
    )
  `);
}

function list(db: Database, limit: number = 50): {{DATA_TYPE}}[] {
  return db.query(`
    SELECT * FROM ${CONFIG.tableName}
    ORDER BY updated_at DESC
    LIMIT ?
  `).all(limit) as {{DATA_TYPE}}[];
}

function get(db: Database, id: number): {{DATA_TYPE}} | null {
  return db.query(`
    SELECT * FROM ${CONFIG.tableName} WHERE id = ?
  `).get(id) as {{DATA_TYPE}} | null;
}

function add(db: Database, data: Partial<{{DATA_TYPE}}>): number {
  const result = db.run(`
    INSERT INTO ${CONFIG.tableName} ({{INSERT_COLUMNS}})
    VALUES ({{INSERT_PLACEHOLDERS}})
  `, {{INSERT_PARAMS}});
  return Number(result.lastInsertRowid);
}

function update(db: Database, id: number, data: Partial<{{DATA_TYPE}}>): boolean {
  const result = db.run(`
    UPDATE ${CONFIG.tableName}
    SET {{UPDATE_SET}}, updated_at = datetime('now')
    WHERE id = ?
  `, {{UPDATE_PARAMS}}, id);
  return result.changes > 0;
}

function remove(db: Database, id: number): boolean {
  const result = db.run(`DELETE FROM ${CONFIG.tableName} WHERE id = ?`, id);
  return result.changes > 0;
}

