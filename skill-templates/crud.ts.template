// ==================== 主程序 ====================

async function main() {
  const args = process.argv.slice(2);
  const command = args[0] || "list";

  if (!existsSync(CONFIG.dbPath)) {
    console.error(`Database not found: ${CONFIG.dbPath}`);
    process.exit(1);
  }

  const db = new Database(CONFIG.dbPath);
  initDB(db);

  switch (command) {
    case "list":
    case "ls":
      printList(list(db));
      break;

    case "get":
      if (!args[1]) {
        console.error("Usage: get <id>");
        process.exit(1);
      }
      printItem(get(db, parseInt(args[1])), "GET");
      break;

    case "add":
    case "create":
      if (!args[1]) {
        console.error("Usage: add <value>");
        process.exit(1);
      }
      const newId = add(db, { {{ADD_DATA}} });
      console.log(`✓ Created item #${newId}`);
      printItem(get(db, newId), "CREATED");
      break;

    case "update":
    case "edit":
      if (!args[1] || !args[2]) {
        console.error("Usage: update <id> <value>");
        process.exit(1);
      }
      if (update(db, parseInt(args[1]), { {{UPDATE_DATA}} })) {
        console.log(`✓ Updated item #${args[1]}`);
        printItem(get(db, parseInt(args[1])), "UPDATED");
      } else {
        console.log(`✗ Item #${args[1]} not found`);
      }
      break;

    case "delete":
    case "rm":
      if (!args[1]) {
        console.error("Usage: delete <id>");
        process.exit(1);
      }
      if (remove(db, parseInt(args[1]))) {
        console.log(`✓ Deleted item #${args[1]}`);
      } else {
        console.log(`✗ Item #${args[1]} not found`);
      }
      break;

    default:
      console.log(`Unknown command: ${command}`);
      console.log("Available: list, get, add, update, delete");
  }

  db.close();
}

main().catch(console.error);
