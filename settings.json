{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "PROXY_MANAGED",
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:15721"
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/state-read-tracker.sh",
            "type": "command"
          },
          {
            "command": "~/.claude/hooks/post-tool-dispatcher.sh",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|Read|Bash|Grep|Glob|Task|WebSearch|WebFetch|TodoWrite|Skill|AskUserQuestion"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/state-read-enforcer.sh",
            "type": "command"
          },
          {
            "command": "~/.claude/hooks/experience-reminder.sh",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "SessionEnd": [
      {
        "command": "/Users/sihaoli/Solar/hooks/session-end-save.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/session-reflect.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/ses-session-end.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/enhanced-memory-writer.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/session-refresh-assets.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/state-session-end.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/state-auto-updater.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/feedback-loop-hook.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/session-output-check.sh",
        "type": "command"
      }
    ],
    "SessionStart": [
      {
        "command": "~/.claude/hooks/solar-session-start.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/context-preload.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/perf-auto-refresh.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/state-inject.sh",
        "type": "command"
      }
    ],
    "UserPromptSubmit": [
      {
        "command": "~/.claude/hooks/personality-anchor-hook.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/asset-reminder.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/cortex-hook.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/intent-learning-hook.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/learning-capture.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/memory-influence.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/ree-first-hook.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/mid-refresh.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/identity-reminder.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/executor-reminder.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/skill-rag-dispatcher.sh",
        "type": "command"
      },
      {
        "command": "~/.claude/hooks/output-persist-reminder.sh",
        "type": "command"
      }
    ]
  },
  "model": "sonnet"
}